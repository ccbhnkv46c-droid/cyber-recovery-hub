{
  "name": "cyber-recovery-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise cyber recovery platform for vulnerability remediation",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "next dev -p 3000",
    "build": "prisma generate && next build",
    "build:vercel": "next build",
    "start": "concurrently -n server,web -c blue,green \"npm run start:server\" \"npm run start:web\"",
    "start:production": "sh scripts/start-production.sh",
    "start:server": "tsx server/index.ts",
    "start:web": "next start -p ${PORT:-3000}",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:sqlite": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "db:setup:postgres": "docker compose up -d postgres && sleep 3 && prisma db push && tsx prisma/seed.ts",
    "setup": "npm install && npm run db:setup",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "go": "npm run setup && npm run dev",
    "postinstall": "prisma generate || true"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.5",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^11.15.0",
    "ioredis": "^5.4.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.468.0",
    "multer": "^1.4.5-lts.1",
    "next": "^14.2.21",
    "nodemailer": "^6.9.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "uuid": "^11.0.3",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

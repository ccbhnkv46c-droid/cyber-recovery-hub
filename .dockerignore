# Dependencies (never copy host node_modules — Prisma engines are platform-specific)
node_modules
node_modules/.prisma
.prisma
npm-debug.log*

# Local env & secrets
.env
.env.local
.env.*.local

# Development database
prisma/dev.db
prisma/dev.db-journal
*.db

# Build artifacts (rebuilt in image)
.next
out

# Git & IDE
.git
.gitignore
.cursor
.vscode

# Tests & docs (not needed at runtime)
tests
*.md
!DEPLOYMENT.md

# Uploads (use Azure Blob / S3 in production)
uploads

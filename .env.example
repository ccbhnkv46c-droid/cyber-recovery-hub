# =============================================================================
# Cyber Recovery Hub — Environment Variables
# Copy to .env for local development. Set in Vercel / Azure App Service for hosting.
# See DEPLOYMENT.md for production guidance.
# =============================================================================

# --- Core ---
NODE_ENV=development

# PostgreSQL (required for Vercel API backend & Azure App Service)
# Local: docker compose up -d postgres
DATABASE_URL=postgresql://crh:crh_dev_password@localhost:5432/cyber_recovery_hub

# SQLite (local dev only — NOT for hosted environments)
# DATABASE_URL="file:./prisma/dev.db"
# Use: npx prisma db push --schema=prisma/schema.sqlite.prisma

# Public application URL (no trailing slash)
# Local:
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Railway production example:
# APP_URL=https://cyber-recovery-hub-production.up.railway.app
# NEXT_PUBLIC_APP_URL=https://cyber-recovery-hub-production.up.railway.app

# --- API (Express backend) ---
API_PORT=3001
API_HOST=0.0.0.0
# Monolith (Railway/Azure Docker): leave API_URL unset — rewrites use http://127.0.0.1:3001
# Do NOT set API_URL to your public Railway URL on a single-service deploy.
# Split deploy (Vercel frontend): set API_URL=https://your-api-host.railway.app
# USE_INTERNAL_API=true

# Comma-separated allowed browser origins
# Local:
CORS_ORIGINS=http://localhost:3000
# Railway production example:
# CORS_ORIGINS=https://cyber-recovery-hub-production.up.railway.app

# Azure / reverse proxy — trust X-Forwarded-* headers for client IP & HTTPS
TRUST_PROXY=true

# Web server port (Azure App Service sets PORT automatically)
PORT=3000

# Apply prisma db push on container start (Azure Docker only — first deploy)
# RUN_DB_PUSH=true

# --- Background jobs ---
ENABLE_BACKGROUND_JOBS=true

# Redis (optional — enables BullMQ job queue for escalations)
# REDIS_URL=redis://localhost:6379

# --- Microsoft Entra ID SSO (recommended for production) ---
# Register app in Azure Portal → App registrations
# Redirect URI must match your public URL: https://<your-domain>/api/auth/entra/callback
# ENTRA_TENANT_ID=your-tenant-id
# ENTRA_CLIENT_ID=your-client-id
# ENTRA_CLIENT_SECRET=your-client-secret
# ENTRA_REDIRECT_URI=https://your-app.azurewebsites.net/api/auth/entra/callback
# ENTRA_DEFAULT_ROLE=ENGINEER

# --- Email notifications (required for SME update emails in production) ---
# Azure: use SendGrid SMTP, Office 365 SMTP, or Azure Communication Services
EMAIL_ENABLED=false
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_SECURE=false
# EMAIL_FROM=cyber-recovery@yourbank.com
# CYBER_RECOVERY_TEAM_EMAIL=cyber-recovery@yourbank.com

# --- Microsoft Teams webhook (optional) ---
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# --- File storage (use Azure Blob or S3 in production — local disk is ephemeral on App Service) ---
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# STORAGE_PROVIDER=azure
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
# AZURE_STORAGE_CONTAINER=crh-evidence
# STORAGE_PROVIDER=s3
# S3_BUCKET=crh-evidence
# S3_REGION=eu-west-1

# --- Virus scanning (optional) ---
# VIRUS_SCAN_ENABLED=true
# CLAMAV_HOST=localhost
# CLAMAV_PORT=3310

# --- Recovery Copilot LLM (optional) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Vercel (frontend-only deploy) ---
# VERCEL=1
# API_URL=https://your-api.azurewebsites.net
# APP_URL=https://your-app.vercel.app
# CORS_ORIGINS=https://your-app.vercel.app
